# GeoSentinel Backend Configuration

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Model Configuration
MODEL_PATH=model/landslide_model.pkl

# Data Files
USERS_FILE=data/users.json
ALERTS_FILE=data/alerts.json
REGIONS_FILE=data/regions.json

# Alert Configuration
HIGH_RISK_THRESHOLD=0.7
ENABLE_EMAIL_ALERTS=False
ENABLE_SMS_ALERTS=False

# SMTP Configuration (if email alerts enabled)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
FROM_EMAIL=geosEntinel@example.com
EMAIL_PASSWORD=your_password_here

# Twilio Configuration (if SMS alerts enabled)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
